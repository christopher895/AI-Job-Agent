# Database
DATABASE_URL=postgresql://jobagent:jobagent@localhost:5432/job_agent
REDIS_URL=redis://localhost:6379

# AI
OPENAI_API_KEY=sk-...

# Notifications
RESEND_API_KEY=re_...
YOUR_EMAIL=you@example.com

# Web app URL (used for CORS and email links)
WEB_URL=http://localhost:3000
APP_URL=http://localhost:3001

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID=your-sheet-id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# PDF generation — path to tectonic binary
# Local (macOS): /opt/homebrew/bin/tectonic
# Railway (Docker): /usr/local/bin/tectonic  (set automatically in Dockerfile)
TECTONIC_PATH=/opt/homebrew/bin/tectonic
